---
import Container from "@components/layout/Container.astro";
---

<section class="py-16 lg:py-20 bg-white" id="servicios">
  <Container>
    <div class="text-center mb-12 fade-in">
      <span
        class="inline-block text-xs font-medium tracking-widest uppercase text-sage mb-2"
      >
        Servicios
      </span>
      <h2 class="text-2xl lg:text-3xl font-display text-sage-dark mt-2">
        Todo lo que necesitas, sin vueltas
      </h2>
      <p class="text-text-secondary mt-3 max-w-lg mx-auto">
        Servicios funerarios completos con precios claros desde el primer
        momento. Sin sorpresas, sin letra chica.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        [
          {
            title: "Servicio Funerario Básico",
            description:
              "Traslado, preparación, capilla ardiente, carroza y trámites legales incluidos.",
            price: "$890.000",
            icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
          },
          {
            title: "Servicio Funerario Completo",
            description:
              "Todo lo básico más cofre premium, floristería, libro de condolencias y coordinación completa.",
            price: "$1.490.000",
            icon: `<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/>`,
          },
          {
            title: "Cremación",
            description:
              "Servicio de cremación completo con urna, certificados y opción de velatorio previo.",
            price: "$690.000",
            icon: `<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
          },
          {
            title: "Gestión de Trámites",
            description:
              "Nos encargamos del papeleo: certificados, inscripciones, cobro de cuota mortuoria y seguros.",
            price: "$120.000",
            icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
          },
        ].map((service) => (
          <div class="bg-cream rounded-xl p-6 border border-border hover:shadow-soft transition-shadow fade-in">
            <div class="w-10 h-10 rounded-lg bg-sage-muted flex items-center justify-center mb-4">
              <svg
                class="w-5 h-5 text-sage"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={service.icon}
              />
            </div>
            <h3 class="font-medium text-text-primary mb-2">{service.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed mb-4">
              {service.description}
            </p>
            <span class="text-sm font-medium text-sage-dark">
              Desde {service.price}
            </span>
          </div>
        ))
      }
    </div>
  </Container>
</section>
