---
import Container from "@components/layout/Container.astro";

const trustItems = [
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    label: "100% Transparente",
    desc: "Sin costos ocultos",
  },
  {
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>`,
    label: "Trato Humano",
    desc: "Acompañamiento real",
  },
  {
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
    label: "Disponible 24/7",
    desc: "Herramientas siempre activas",
  },
  {
    icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`,
    label: "Herramientas Gratis",
    desc: "Sin compromiso",
  },
];
---

<section class="py-8 bg-cream-dark/50 border-y border-border/50">
  <Container>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {trustItems.map((item) => (
        <div class="flex flex-col items-center text-center gap-2 fade-in">
          <svg
            class="w-6 h-6 text-sage"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={item.icon}
          />
          <span class="text-sm font-medium text-sage-dark">{item.label}</span>
          <span class="text-xs text-text-muted">{item.desc}</span>
        </div>
      ))}
    </div>
  </Container>
</section>
