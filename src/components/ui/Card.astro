---
interface Props {
  class?: string;
  hover?: boolean;
  padding?: "sm" | "md" | "lg";
}

const { class: className = "", hover = false, padding = "md" } = Astro.props;

const paddings: Record<string, string> = {
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
};

const hoverStyles = hover
  ? "hover:shadow-lifted hover:-translate-y-1 transition-all duration-300"
  : "";
---

<div
  class:list={[
    "bg-white rounded-2xl border border-border shadow-card",
    paddings[padding],
    hoverStyles,
    className,
  ]}
>
  <slot />
</div>
